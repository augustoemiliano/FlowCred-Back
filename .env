PROJECT_NAME=FlowCred API
PROJECT_VERSION=0.1.0
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=flowcred
POSTGRES_USER=flowcred
POSTGRES_PASSWORD=change_me

BACKEND_CORS_ORIGINS=http://localhost:5173

JWT_SECRET_KEY=change_this_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: first boot creates admin if both are set (see docker entrypoint).
INITIAL_ADMIN_EMAIL=admin@flowcred.local
INITIAL_ADMIN_PASSWORD=ChangeMe123!
