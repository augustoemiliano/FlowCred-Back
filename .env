PROJECT_NAME=FlowCred API
PROJECT_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Dev local: SQLite. No Docker, o compose define sqlite:////app/data/db.local.
DATABASE_URL=sqlite:///./db.local

BACKEND_CORS_ORIGINS=http://localhost:5173

JWT_SECRET_KEY=change_this_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Entrypoint / script ensure_admin: cria ou sincroniza o admin (dev apenas).
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin

# Cliente + proposta demo para quem clonar o repo (idempotente). Desligue com 0 em produção.
SEED_DEV_DATA=1

UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
