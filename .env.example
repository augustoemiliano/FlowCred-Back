PROJECT_NAME=FlowCred API
PROJECT_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Por omissão o código usa SQLite em ./db.local (dev local).
# No Docker, o compose define sqlite:////app/data/db.local (volume flowcred_data).
DATABASE_URL=

# Opcional: Postgres (só preencha se quiser deixar de usar SQLite).
POSTGRES_SERVER=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

BACKEND_CORS_ORIGINS=http://localhost:5173

JWT_SECRET_KEY=change_this_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# O entrypoint cria ou atualiza o admin se ambos estiverem definidos.
# Apenas para desenvolvimento: admin/admin é fraco; altere em produção.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin

# 1 = cria cliente CPF 52998224725 + 1 proposta demo (idempotente). Use 0 em produção.
SEED_DEV_DATA=1

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760
